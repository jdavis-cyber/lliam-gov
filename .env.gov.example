# =============================================================================
# Lliam-GOV — Governance .env Template  (.env.gov.example)
# =============================================================================
#
# | Field          | Value                                                     |
# |----------------|-----------------------------------------------------------|
# | Document       | Lliam-GOV Governance Environment Template                 |
# | Owner          | Lliam-GOV Program                                          |
# | Classification | CUI//SP-PRIV (template — mark per instance)                |
# | Version        | 0.1 DRAFT                                                  |
#
# WHAT THIS IS
# -----------------------------------------------------------------------------
# The process-environment half of the Lliam-GOV CUI baseline — the env levers
# that the YAML overlay (cli-config.gov.yaml) cannot express, read by the
# in-process guards every tool call passes through (redact.py, file_safety.py,
# url_safety.py, lazy_deps.py, approval.py, tirith_security.py).
#
# HOW TO USE  (PATH-FREEZE: every var below is an EXISTING Hermes/Lliam env key;
# this template only SETS VALUES — it renames/moves nothing)
#   1. Copy to the active env file the agent loads:  $HERMES_HOME/.env
#        cp .env.gov.example  $HERMES_HOME/.env   # then fill the <SET ...> values
#   2. Do NOT commit a filled copy (host paths / secrets). Commit only this template.
#   3. For high-side use, resolve real secrets from the OS keychain / Bitwarden
#      (LG-DP-05/08), NOT cleartext here. Placeholders mark WHICH keys exist.
#
# BUILD ORDER: lines are tagged [ACTIVE @ P0.x] for the step that turns them on;
# Phase-1/2 levers are left as commented <SET> scaffolds.
# =============================================================================


# =============================================================================
# [ACTIVE @ P0.1]  CONFIG SELECTION  —  LG-CH-01
# -----------------------------------------------------------------------------
# Point the agent at the pinned, version-controlled governance overlay instead
# of editing the shipped example. HERMES_CONFIG is on the config.py env allowlist
# (config.py:198) and is resolved by the additive selector config._gov_overlay_path.
HERMES_CONFIG=<SET path/to/cli-config.gov.yaml>
HERMES_HOME=<SET e.g. /opt/lliam-gov/.hermes>   # FDE-encrypted storage (LG-DP-07)


# =============================================================================
# [ACTIVE @ P0.2]  FILE-WRITE CONFINEMENT (positive safe-root)  —  LG-AZ-04
#                  (also LG-DP-08 key-protection, LG-AU-07 audit-log protection)
# -----------------------------------------------------------------------------
# agent/file_safety.py get_safe_write_roots() reads this (file_safety.py:84).
# WITHOUT it, writes are allowed anywhere not on the credential denylist. Setting
# it turns on a POSITIVE allowlist: the file_write tool refuses any write whose
# resolved path is not under one of these os.pathsep-separated roots.
# MUST EXCLUDE $HERMES_HOME/logs — the audit ledger lives there and must stay
# unwritable by the agent's own tools (LG-AU-07).
HERMES_WRITE_SAFE_ROOT=<SET /opt/lliam-gov/workspace:/opt/lliam-gov/outputs>


# =============================================================================
# [ACTIVE @ P0.2]  SECRET REDACTION  —  LG-DP-03  (bridges YAML security.redact_secrets)
# -----------------------------------------------------------------------------
# agent/redact.py snapshots this at IMPORT (redact.py:68), so a mid-session
# `export HERMES_REDACT_SECRETS=false` cannot silently disable masking. Covers
# logs, tool output, terminal stdout, and file reads; same engine the audit
# ledger runs over args/results before persistence (LG-AU-05). Keep it true.
HERMES_REDACT_SECRETS=true


# =============================================================================
# [ACTIVE @ P0.1/P0.2]  ENV BRIDGES FOR ALREADY-PINNED OVERLAY POSTURE
# -----------------------------------------------------------------------------
# These mirror keys already pinned in cli-config.gov.yaml so the env layer cannot
# re-open them. All capability-preserving for CUI workloads.
HERMES_DISABLE_LAZY_INSTALLS=1   # LG-SS-07: seal the venv, no runtime PyPI installs (bridges security.allow_lazy_installs:false)
HERMES_ALLOW_PRIVATE_URLS=false  # LG-NE-02: SSRF/private-IP/metadata egress stays blocked
TIRITH_ENABLED=true              # LG-PI-05: keep the pre-exec content scanner on
TIRITH_FAIL_OPEN=false           # LG-PI-05: scanner fails CLOSED (bridges security.tirith_fail_open:false)
HERMES_INTERACTIVE=1             # LG-HO-06: ensure an approver context exists so the manual gate is reachable (no silent auto-approve)
# DO NOT set HERMES_YOLO_MODE or SUDO_PASSWORD in a CUI profile — both bypass approvals.


# =============================================================================
# SCAFFOLD — Phase-1/2 env levers (turned on in their dedicated steps)
# =============================================================================
# [P1  IA-11 / CH-09]  API server RCE gate (set in Phase 1; placeholder now):
API_SERVER_KEY=                  # <SET strong-random in Phase 1 — prefer keychain/Bitwarden, not cleartext>
# API_SERVER_HOST=<SET 127.0.0.1 or authorized bind address>
#
# [P1  DP-06]   HERMES_CA_BUNDLE=<SET path/to/org-or-FIPS ca-bundle.pem>   # do NOT set HERMES_SKIP_SSL_GUARD
# [P1  AU-10]   HERMES_DASHBOARD_BASIC_AUTH_USERNAME=<SET operator username>
# [P2  NE-01/04/05]  HTTP_PROXY=<SET http://egress-proxy:3128> ; HTTPS_PROXY=<...> ; NO_PROXY=<SET localhost,127.0.0.1,...>
# [P2  MP-01/02]     HERMES_INFERENCE_PROVIDER=<SET in-boundary id> ; HERMES_INFERENCE_MODEL=<...> ; HERMES_BASE_URL=<...>
#
# -----------------------------------------------------------------------------
# Built on Hermes Agent (Nous Research, MIT). Governance overlay is additive and
# capability-preserving.
# =============================================================================
