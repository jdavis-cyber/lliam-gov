# Lliam-GOV governed production profile (LG-4.7 / AI-224)
# Copy to the production host's launch environment. Do NOT commit a filled-in
# copy. LLIAM_GOV_ALLOW_NON_FIPS must never appear in this file.

HERMES_HOME=/Users/OPERATOR/.lliam-gov
LLIAM_GOV_PROFILE=production
LLIAM_GOV_ENCRYPT_STATE=1
LLIAM_GOV_EGRESS_ENFORCE=1
LLIAM_GOV_CAPABILITY_ENFORCE=1
LLIAM_GOV_SELFMOD_GATE=1

# Optional narrowing:
# LLIAM_GOV_CAPABILITIES=fs_read,fs_write,messaging,memory_write
# LLIAM_GOV_PRIVILEGED_USERS=operator_username
# Egress allowlist lives at $HERMES_HOME/egress-allowlist.txt (one host[:port] per line)
